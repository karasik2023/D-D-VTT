generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  username     String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  rooms        Room[]
}

model Room {
  id        String   @id @default(cuid())
  code      String   @unique
  owner     User     @relation(fields: [ownerId], references: [id])
  ownerId   String
  createdAt DateTime @default(now())
}