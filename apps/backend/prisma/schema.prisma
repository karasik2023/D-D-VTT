generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model RoomMember {
  id       String @id @default(cuid())
  roomCode String
  userId   String
  joinedAt DateTime @default(now())
  room     Room   @relation(fields: [roomCode], references: [code])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([roomCode, userId])
}

model User {
  id           String       @id @default(cuid())
  username     String
  email        String       @unique
  passwordHash String
  createdAt    DateTime     @default(now())
  rooms        Room[]
  memberships  RoomMember[]
  assets    Asset[]
}

model Room {
  id        String       @id @default(cuid())
  code      String       @unique
  name      String       @default("Новая комната")
  owner     User         @relation(fields: [ownerId], references: [id])
  ownerId   String
  createdAt DateTime     @default(now())
  members   RoomMember[]
}

model Asset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "TOKEN" | "MAP" | "SCENE"
  name      String
  filename  String   // имя файла на диске
  url       String   // /uploads/tokens/abc123.png
  size      Int      // байты
  createdAt DateTime @default(now())

  @@index([userId, type])
}